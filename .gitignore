# ================================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ================================================================================
# IDE / Editor
# ================================================================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ================================================================================
# Testing
# ================================================================================
coverage/
.nyc_output/
*.lcov
.jest-cache/

# ================================================================================
# Logs
# ================================================================================
logs/
*.log
pids
*.pid
*.seed
*.pid.lock

# ================================================================================
# Temporary Files
# ================================================================================
tmp/
temp/
*.tmp

# ================================================================================
# Operating System
# ================================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ================================================================================
# Production Secrets (IMPORTANT!)
# ================================================================================
secrets/
*.key
*.pem
*.cert
*.csr

# API Keys and Tokens
.api-keys
.secrets

# Database
*.sqlite
*.db
*.sql

# ================================================================================
# Deployment
# ================================================================================
.vercel
.netlify
.firebase/

# ================================================================================
# Package Manager
# ================================================================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ================================================================================
# Analytics & Monitoring
# ================================================================================
.sentry/

# ================================================================================
# AI DOMINATOR Specific
# ================================================================================
# Local data stores (if using files instead of localStorage)
data/
uploads/
screenshots/

# Generated documentation
docs/api/
docs/generated/

# Backup files
*.backup
*.bak

# ================================================================================
# Archive Files
# ================================================================================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# ================================================================================
# Keep These Files
# ================================================================================
!.gitkeep
!.gitignore
!README.md
!LICENSE
