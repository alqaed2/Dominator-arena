node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# ================================================================================
# Build Output
# ================================================================================
dist/
dist-ssr/
build/
.cache/

# ================================================================================
